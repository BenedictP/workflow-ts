{
  "name": "workflow-ts",
  "version": "0.0.1",
  "private": true,
  "description": "A TypeScript implementation of Square's Workflow architecture",
  "keywords": [
    "workflow",
    "state-machine",
    "unidirectional",
    "reactive",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "publish": "pnpm -r build && pnpm -r publish --access public",
    "readme:verify-example": "node scripts/verify-readme-example.mjs"
  },
  "pnpm": {
    "overrides": {
      "minimatch@^3.0.0": "^3.1.4",
      "rollup@^4.0.0": "^4.59.0",
      "brace-expansion@^1.0.0": "^1.1.13",
      "yaml@^2.0.0": "^2.8.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
