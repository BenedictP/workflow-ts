{
  "name": "@workflow-ts/react",
  "version": "0.1.3",
  "description": "React bindings for workflow-ts",
  "keywords": [
    "workflow",
    "state-machine",
    "react"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/BenedictP/workflow-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BenedictP/workflow-ts.git"
  },
  "bugs": {
    "url": "https://github.com/BenedictP/workflow-ts/issues"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@workflow-ts/core": "workspace:*",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@workflow-ts/core": "workspace:*",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
